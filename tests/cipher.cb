# `#` makes the rest of the line a comment
#Header imports, similar to #include
#Can also be `header <standard> as std` for single import per line
header(
    <standard> as std,
);

#List of character types

std.List<Char> alphabet = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm', 'n', 'o', 'p', 'q', 'r', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z'];

#Encode function that takes a string and an int and returns a string

String encode(String input, Int shift) {
    String output = "";
    for (Char character : input) {
        Char outputCharacter = switch (true) {
            case ((alphabet.find(character.toLower()) + shift).isNegative()):
                alphabet[26 + (alphabet.find(character.toLower()) + shift)];
                break;
            case ((alphabet.find(character.toLower()) + shift) > alphabet.size() - 1):
                alphabet[alphabet.find(character.toLower()) + shift - 26];
                break;
            default:
                alphabet[alphabet.find(character.toLower()) + shift];
        };
        if (character.isUpper()) {
            outputCharacter.apply{ toUpper() }
        }
        output.pushBack(outputCharacter);
    }
    return output;
}

#Decode function — reverses a Caesar cipher by negating the shift.
#Written by Claude to test grammar inferrability from cipher.flnt.
#Mirrors encode exactly, subtracting shift instead of adding it.
#Defined before main() as required by declaration-before-use rules.

String decode(String input, Int shift) {
    String output = "";
    for (Char character : input) {
        Char outputCharacter = switch (true) {
            case ((alphabet.find(character.toLower()) - shift).isNegative()):
                alphabet[26 + (alphabet.find(character.toLower()) - shift)];
                break;
            case ((alphabet.find(character.toLower()) - shift) > alphabet.size() - 1):
                alphabet[alphabet.find(character.toLower()) - shift - 26];
                break;
            default:
                alphabet[alphabet.find(character.toLower()) - shift];
        };
        if (character.isUpper()) {
            outputCharacter.apply{ toUpper() }
        }
        output.pushBack(outputCharacter);
    }
    return output;
}

#Main function, runs when program is executed

Int main() {
    String code = encode("This is a caesar cipher", 8);
    #The decode function was written by Claude to test how understandable the grammar is from a blind start
    String decoded = decode(code, 8);

    std.print(decoded);

    return 0;
}
